{
  "cds_version": "1.0",
  "name": "ccplugin-backend-forge",
  "type": "sdk",
  "input_patterns": [
    {
      "type": "machine_api",
      "description": "Agent-to-agent API: create_project, deploy, db_exec, db_schema, auth_setup, env_set, storage_create, status, destroy"
    }
  ],
  "output_patterns": [
    {
      "type": "structured_output",
      "description": "API responses + deployed infrastructure"
    },
    {
      "type": "terminal_text",
      "max_lines": 20
    }
  ],
  "lifecycle": {
    "preflight": {
      "required_tools": [
        "npx",
        "supabase"
      ],
      "required_secrets": [
        "SUPABASE_ACCESS_TOKEN"
      ],
      "required_mcp": [
        "firebase"
      ]
    }
  },
  "error_handling": {
    "retry_network": true,
    "max_retries": 3,
    "fallback": "manual CLI commands"
  }
}
