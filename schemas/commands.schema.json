{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "backend-forge Command Schemas",
  "description": "JSON Schema definitions for all backend-forge commands",
  "definitions": {
    "dry_run": {
      "type": "boolean",
      "default": false
    },
    "error_response": {
      "type": "object",
      "properties": {
        "ok": { "const": false },
        "error": { "type": "string", "enum": ["missing_secret", "quota_exceeded", "api_error", "not_found", "blocked_sql", "confirm_mismatch", "rate_limited", "state_version_unsupported", "invalid_input"] },
        "detail": { "type": "string" }
      },
      "required": ["ok", "error"]
    },
    "create_project": {
      "input": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$", "maxLength": 50 },
          "framework": { "type": "string", "enum": ["nextjs", "remix", "nuxt", "sveltekit", "astro"], "default": "nextjs" },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        },
        "required": ["name"]
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "vercel_url": { "type": "string", "format": "uri" },
          "supabase_url": { "type": "string", "format": "uri" },
          "env_set": { "type": "boolean" }
        },
        "required": ["ok"]
      }
    },
    "deploy": {
      "input": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        },
        "required": ["project"]
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "url": { "type": "string", "format": "uri" },
          "status": { "type": "string", "enum": ["ready", "building", "error"] }
        },
        "required": ["ok"]
      }
    },
    "db_exec": {
      "input": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "sql": { "type": "string", "maxLength": 10000 },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        },
        "required": ["project", "sql"]
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "rows": { "type": "array" },
          "row_count": { "type": "integer" }
        },
        "required": ["ok"]
      }
    },
    "db_schema": {
      "input": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "tables": { "type": "object", "additionalProperties": { "type": "object", "additionalProperties": { "type": "string" } } },
          "rls": { "type": "boolean", "default": true },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        },
        "required": ["project", "tables"]
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "tables_created": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["ok"]
      }
    },
    "auth_setup": {
      "input": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "providers": { "type": "array", "items": { "type": "string", "enum": ["email", "google", "facebook", "apple", "github", "twitter", "discord", "linkedin", "spotify", "twitch", "slack", "notion", "bitbucket", "gitlab", "azure", "keycloak", "phone"] } },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        },
        "required": ["project", "providers"]
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "providers_enabled": { "type": "array", "items": { "type": "string" } },
          "pending_config": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["ok"]
      }
    },
    "env_set": {
      "input": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "vars": { "type": "object", "additionalProperties": { "type": "string" } },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        },
        "required": ["project", "vars"]
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "count": { "type": "integer" }
        },
        "required": ["ok"]
      }
    },
    "storage_create": {
      "input": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "bucket": { "type": "string" },
          "public": { "type": "boolean", "default": false },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        },
        "required": ["project", "bucket"]
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["ok"]
      }
    },
    "setup_check": {
      "input": {
        "type": "object",
        "properties": {
          "cmd": { "type": "string", "const": "setup_check" }
        },
        "required": ["cmd"]
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "tokens": {
            "type": "object",
            "properties": {
              "vercel": { "type": "boolean" },
              "supabase": { "type": "boolean" }
            },
            "required": ["vercel", "supabase"]
          },
          "cli": {
            "type": "object",
            "properties": {
              "vercel": { "type": "boolean" },
              "supabase": { "type": "boolean" }
            },
            "required": ["vercel", "supabase"]
          },
          "ready": { "type": "boolean" },
          "missing": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["ok", "tokens", "cli", "ready", "missing"]
      }
    },
    "status": {
      "input": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        }
      },
      "output": {
        "oneOf": [
          {
            "description": "Single project response",
            "type": "object",
            "properties": {
              "ok": { "const": true },
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "status": { "type": "string", "enum": ["ready", "building", "error"] },
              "vercel_id": { "type": "string" },
              "supabase_ref": { "type": "string" },
              "framework": { "type": "string" },
              "region": { "type": "string" }
            },
            "required": ["ok"]
          },
          {
            "description": "All projects response",
            "type": "object",
            "properties": {
              "ok": { "const": true },
              "projects": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "url": { "type": "string", "format": "uri" },
                    "status": { "type": "string", "enum": ["active", "inactive"] },
                    "vercel_id": { "type": "string" },
                    "supabase_ref": { "type": "string" }
                  },
                  "required": ["name", "status"]
                }
              }
            },
            "required": ["ok", "projects"]
          }
        ]
      }
    },
    "list_projects": {
      "input": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "projects": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "url": { "type": "string", "format": "uri" },
                "status": { "type": "string", "enum": ["active", "inactive"] },
                "vercel_id": { "type": "string" },
                "supabase_ref": { "type": "string" }
              },
              "required": ["name", "status"]
            }
          }
        },
        "required": ["ok", "projects"]
      }
    },
    "update_project": {
      "input": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "framework": { "type": "string", "enum": ["nextjs", "remix", "nuxt", "sveltekit", "astro"] },
          "region": { "type": "string" },
          "env": { "type": "object", "additionalProperties": { "type": "string" } },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        },
        "required": ["project"],
        "minProperties": 2
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "updated_fields": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["ok", "updated_fields"]
      }
    },
    "destroy": {
      "input": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "confirm": { "type": "string", "description": "Must match project name exactly" },
          "dry_run": { "$ref": "#/definitions/dry_run" }
        },
        "required": ["project", "confirm"]
      },
      "output": {
        "type": "object",
        "properties": {
          "ok": { "const": true }
        },
        "required": ["ok"]
      }
    }
  }
}
